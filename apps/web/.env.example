# Single-user auth (Brand Book product: Asicom; internal tool)
ASICOM_USER=tripon
# Password as a scrypt hash "salt:hash" (hex). Generate one with:
#   node scripts/hash-password.mjs 'your-password'
ASICOM_PASSWORD_HASH=
# Secret for signing the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Storage (GDPR: raw images on disk, purged after Emis; structured data in SQLite)
DATABASE_PATH=./data/asicom.db
UPLOAD_DIR=./data/uploads

# Vision extraction (Claude). Required to run the pipeline. https://console.anthropic.com/
ANTHROPIC_API_KEY=
